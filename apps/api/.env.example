# Example: alice@example.com,*@company.com
BETTER_AUTH_ADMIN_EMAILS=alice@example.com
BETTER_AUTH_SECRET=__GENERATE_SECRET__
BETTER_AUTH_SOLANA_SIGN_IN_ENABLED=true
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001
DATABASE_AUTH_TOKEN=no-token
DATABASE_URL=http://localhost:8080
# Optional: comma-separated Discord user IDs to auto-promote to admin on first link
DISCORD_ADMIN_IDS=
# Discord OAuth (needed for "Sign in with Discord"). Get it at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Solana configuration
SOLANA_CLUSTER=devnet
SOLANA_ENDPOINT=https://api.devnet.solana.com
SOLANA_ENDPOINT_PUBLIC=https://api.devnet.solana.com
# Optional: URL of the frontend, will use BETTER_AUTH_URL if not provided
WEB_URL=http://localhost:3001
