# Optional: local API server bind port. Defaults to 3000.
#API_PORT=3000
# Base URL for the API. Local development defaults to http://localhost:3000.
API_URL=http://localhost:3000
BETTER_AUTH_SECRET=__GENERATE_SECRET__
BETTER_AUTH_SOLANA_SIGN_IN_ENABLED=true
# Local split-origin dev default. For the single-container Docker flow use http://localhost:3000.
CORS_ORIGINS=http://localhost:3001
# Optional for local libsql and the Docker sidecar.
DATABASE_AUTH_TOKEN=
DATABASE_URL=http://localhost:8080
# Optional: comma-separated Discord user IDs to auto-promote to admin on first link
DISCORD_ADMIN_IDS=
# Optional: set false to disable Discord bot startup in the API process
DISCORD_BOT_START=false
# Discord bot token for the API-hosted Discord bot. Get it at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Discord OAuth (needed for "Sign in with Discord"). Get it at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Optional: guild ID for guild-scoped Discord command registration
DISCORD_GUILD_ID=
# Helius configuration for asset indexing
HELIUS_API_KEY=
HELIUS_CLUSTER=devnet
# Optional: enable debug logging for specific areas: all, asset-index, indexer
LOG_DEBUG_CATEGORIES=all
# Use readable logs by default in local development. Set true to force JSON output.
LOG_JSON=false
# Optional: set false to disable scheduled jobs in the API process
SCHEDULER_START=true
# Optional: comma-separated Solana wallet addresses to auto-promote to admin on first link or sign-in
SOLANA_ADMIN_ADDRESSES=
# Solana configuration
SOLANA_CLUSTER=devnet
SOLANA_ENDPOINT=https://api.devnet.solana.com
SOLANA_ENDPOINT_PUBLIC=https://api.devnet.solana.com
# Local split-origin dev default. For the single-container Docker flow use http://localhost:3000.
# Optional: URL of the frontend. Runtime consumers that need a public app URL
# (for example packages/auth/src/index.ts and packages/discord/src/discord-env.ts)
# fall back to API_URL when this is unset; the env schema does not apply that fallback.
WEB_URL=http://localhost:3001
