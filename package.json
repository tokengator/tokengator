{
  "name": "tokengator",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@libsql/client": "0.17.2",
      "@logtape/hono": "^2.0.5",
      "@logtape/logtape": "^2.0.5",
      "@orpc/client": "^1.13.13",
      "@orpc/openapi": "^1.13.13",
      "@orpc/server": "^1.13.13",
      "@orpc/zod": "^1.13.13",
      "@solana/kit": "^6.1.0",
      "@types/bun": "^1.3.4",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "@wallet-ui/react": "^4.0.1",
      "better-auth": "1.5.6",
      "better-auth-solana": "1.0.0-canary-20260330165420",
      "discord.js": "^14.22.1",
      "dotenv": "^17.2.2",
      "drizzle-orm": "^0.45.2",
      "hono": "^4.8.2",
      "libsql": "0.5.29",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "zod": "^4.1.13"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "check-types": "turbo check-types",
    "ci": "bun run lint && turbo run build check-types test test:e2e test:integration",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:local": "bun run --cwd packages/db db:local",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:push": "bun run --cwd packages/db db:push",
    "db:reset": "rm packages/db/local.db*",
    "db:seed": "bun run --cwd packages/db db:seed",
    "db:studio": "bun run --cwd packages/db db:studio",
    "dev": "turbo dev",
    "dev:api": "bun --cwd apps/api dev",
    "dev:local": "bun run ./scripts/dev-local.ts",
    "dev:web": "bun --cwd apps/web dev",
    "docker:up": "docker compose --env-file apps/api/.env up --build",
    "lint": "oxlint && oxfmt --check",
    "lint:fix": "oxlint --fix && oxfmt --write",
    "setup": "bun run ./scripts/setup.ts",
    "start:api": "bun run db:push && bun run --cwd apps/api start",
    "start:web": "bun run --cwd apps/web serve -- --host 0.0.0.0 --port 3001",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:integration": "turbo run test:integration"
  },
  "dependencies": {
    "@tokengator/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tokengator/config": "workspace:*",
    "@types/bun": "catalog:",
    "eslint-plugin-perfectionist": "^5.7.0",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.21",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.11"
}
