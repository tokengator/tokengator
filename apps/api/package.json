{
  "name": "api",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b --noEmit",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile api",
    "dev": "bun run --hot src/index.ts",
    "discord:invite": "bun run src/print-discord-invite-link.ts",
    "discord:provision-roles": "bun run src/provision-discord-roles.ts",
    "discord:register": "bun run src/register-discord.ts",
    "jobs": "bun run src/run-scheduled-jobs.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@tokengator/api": "workspace:*",
    "@tokengator/auth": "workspace:*",
    "@tokengator/db": "workspace:*",
    "@tokengator/discord": "workspace:*",
    "@tokengator/env": "workspace:*",
    "@tokengator/logger": "workspace:*",
    "better-auth": "catalog:",
    "discord.js": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "tanstack-start-bun-server": "1.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tokengator/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
