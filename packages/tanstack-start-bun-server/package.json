{
  "name": "tanstack-start-bun-server",
  "version": "0.1.0",
  "description": "Bun server helpers for serving TanStack Start production builds",
  "files": [
    "dist",
    "README.md",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b --noEmit",
    "prepublishOnly": "bun run build",
    "test": "bun test ./test"
  },
  "devDependencies": {
    "@tokengator/config": "workspace:*",
    "@tokengator/logger": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
