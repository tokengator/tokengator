{
  "name": "@tokengator/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:local": "turso dev --db-file local.db",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run ./src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test": "bun test ./test",
    "test:integration": "bun test --timeout 15000 ./test-integration"
  },
  "dependencies": {
    "@libsql/client": "catalog:",
    "@tokengator/env": "workspace:*",
    "@tokengator/logger": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "libsql": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tokengator/config": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5"
  }
}
